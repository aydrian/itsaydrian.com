{
	"compatibility_date": "2026-05-05",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "itsaydrian",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	// Run: wrangler kv namespace create TRAVEL_INQUIRIES
	// Replace the id and preview_id values with the output from that command.
	"kv_namespaces": [
		{
			"binding": "TRAVEL_INQUIRIES",
			"id": "REPLACE_WITH_PRODUCTION_KV_ID",
			"preview_id": "REPLACE_WITH_PREVIEW_KV_ID"
		}
	]
}
